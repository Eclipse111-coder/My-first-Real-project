<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="388.0" prefWidth="459.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.passwordman.fxmlpratcise.exchangerController">
    <GridPane layoutX="7.0" prefHeight="400.0" prefWidth="513.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="112.0" minWidth="10.0" prefWidth="101.0" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="99.0" minWidth="10.0" prefWidth="99.0" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="99.0" minWidth="10.0" prefWidth="99.0" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="99.0" minWidth="10.0" prefWidth="99.0" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="99.0" minWidth="10.0" prefWidth="99.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <Button fx:id="btnConvert" mnemonicParsing="false" onAction="#handleConvert" text="convert" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="1" />
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Choose your currency: " wrappingWidth="110.30899047851562" GridPane.rowIndex="2" />
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Enter your sum: " />
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Your value:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="textFieldEntering" GridPane.rowIndex="1" />
        <TextField fx:id="textFieldResult" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <ChoiceBox fx:id="currencyChoose" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
       <Button GridPane.halignment="RIGHT" GridPane.valignment="TOP" onAction="#toggleMenu" text="☰" GridPane.columnIndex="4" />
    </GridPane>
    <VBox fx:id="sideMenu" layoutX="420" prefHeight="400" prefWidth="100" style="-fx-background-color: 2c3e50" visible="false">

        <Button onAction="#switchToMenu" prefHeight="26.0" prefWidth="108.0" text="Main" />
        <Button onAction="#openSettings" prefHeight="26.0" prefWidth="101.0" text="settings" />
        <Button mnemonicParsing="false" onAction="#exchanger" prefHeight="26.0" prefWidth="104.0" text="Exchanger" />
        <Button mnemonicParsing="false" text="Password Generator">
            <font>
                <Font size="10.0" />
            </font>
        </Button>
        <Button mnemonicParsing="false" onAction="#TODOset" prefHeight="26.0" prefWidth="133.0" text="TODO List" />
        <Button mnemonicParsing="false" onAction="#logOut" prefHeight="26.0" prefWidth="104.0" text="Log out" />
    </VBox>
</AnchorPane>
